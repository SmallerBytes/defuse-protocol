{
  "name": "defuse-protocol",
  "version": "1.0.0",
  "description": "Cooperative multiplayer puzzle game: one Defuser, many Experts, one ticking device.",
  "main": "server/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "node tests/smoke.js",
    "build:solo": "npx --yes esbuild server/game.js --bundle --format=esm --outfile=public/js/solo/game-bundle.js --platform=browser"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "license": "MIT",
  "devDependencies": {
    "socket.io-client": "^4.8.3"
  }
}
